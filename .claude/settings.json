{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "powershell.exe -NonInteractive -ExecutionPolicy Bypass -File \"G:/PHONG TRO/app/.claude/auto-commit.ps1\"",
            "timeout": 30,
            "statusMessage": "Auto-committing changes to Git..."
          }
        ]
      }
    ]
  }
}
